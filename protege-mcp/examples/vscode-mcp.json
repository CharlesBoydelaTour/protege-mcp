{
    "inputs": [
        {
            "id": "relayScript",
            "type": "promptString",
            "description": "Absolute path to protege-mcp-relay.py (e.g. /Users/me/code/protege-mcp/protege-mcp/relay/protege-mcp-relay.py)."
        },
        {
            "id": "port",
            "type": "promptString",
            "description": "TCP port the protege-mcp bundle is listening on (leave blank for the default 47800).",
            "default": ""
        },
        {
            "id": "protegeHome",
            "type": "promptString",
            "description": "Absolute path to the extracted Protege Desktop directory (the folder containing run.sh / run.bat, e.g. /Users/me/tools/Protege-5.6.10-SNAPSHOT). Only used by the spawn-mode entries."
        },
        {
            "id": "javaHome",
            "type": "promptString",
            "description": "Optional JAVA_HOME for Protege (leave blank to use the system JDK / bundled jre). Only used by the spawn-mode entries.",
            "default": ""
        }
    ],
    "servers": {
        "protege-mcp-attach": {
            "type": "stdio",
            "command": "python3",
            "args": ["${input:relayScript}"],
            "env": {
                "PROTEGE_MCP_PORT": "${input:port}"
            }
        },
        "protege-mcp-spawn": {
            "type": "stdio",
            "command": "${input:protegeHome}/run.sh",
            "args": [],
            "env": {
                "CMD_OPTIONS": "-Dapple.awt.UIElement=true",
                "JAVA_HOME": "${input:javaHome}"
            }
        },
        "protege-mcp-spawn-windows": {
            "type": "stdio",
            "command": "${input:protegeHome}/run.bat",
            "args": [],
            "env": {
                "JAVA_HOME": "${input:javaHome}"
            }
        }
    }
}
